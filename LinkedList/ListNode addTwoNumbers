class Solution {
    public ListNode addTwoNumbers(ListNode l1, ListNode l2) {
        // A "dummy" starter node so we always have a place to attach results.
        ListNode dummy = new ListNode(0);
        ListNode current = dummy;   // pointer that builds the result list
        int carry = 0;              // the "1" you carry over when sum >= 10

        // Keep going while either list still has digits left
        while (l1 != null || l2 != null) {

            // Step 1: get the digit from each list (use 0 if that list ended)
            int digit1 = 0;
            if (l1 != null) {
                digit1 = l1.val;
            }

            int digit2 = 0;
            if (l2 != null) {
                digit2 = l2.val;
            }

            // Step 2: add the two digits plus anything carried over
            int sum = digit1 + digit2 + carry;

            // Step 3: figure out the digit to keep and the carry for next time
            carry = sum / 10;          // 13 / 10 = 1  -> carry
            int digitToStore = sum % 10; // 13 % 10 = 3 -> keep this digit

            // Step 4: attach the new digit to our result list
            current.next = new ListNode(digitToStore);
            current = current.next;

            // Step 5: move forward in each list (only if it has more digits)
            if (l1 != null) {
                l1 = l1.next;
            }
            if (l2 != null) {
                l2 = l2.next;
            }
        }

        // After the loop, if there's still a carry left, add it as a final digit
        // Example: 5 + 5 = 10, the leftover "1" becomes a new node
        if (carry > 0) {
            current.next = new ListNode(carry);
        }

        // dummy.next skips past the starter node and gives the real answer
        return dummy.next;
    }
}
